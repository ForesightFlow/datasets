    given-names: Maksym
    affiliation: "Devnull FZCO, Dubai, UAE"
    email: maksym@devnull.ae
version: "1.0"
date-released: "2026-04-28"
license: CC-BY-4.0
repository-code: "https://github.com/ForesightFlow/datasets"
url: "https://github.com/ForesightFlow/datasets/tree/main/polymarket-resolution-typology"
keywords:
  - prediction markets
  - polymarket
  - market microstructure
  - resolution mechanism
  - informed trading
  - dataset
  - classification
related-identifiers:
